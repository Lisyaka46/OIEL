<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:IEL="clr-namespace:IEL.UserElementsControl;assembly=LibraryIEL"
    x:Class="OIEL.UserElementsControl.OPLBrowserPage"
    mc:Ignorable="d" 
    d:DesignHeight="380.454" d:DesignWidth="487.727">
    <Control.Resources>
        <ResourceDictionary Source="/LibraryIEL;component/CORE/Resources/VisualDictionary.xaml"/>
    </Control.Resources>
    <Border x:Name="BorderMain" BorderBrush="Black" BorderThickness="2,2,2,2" CornerRadius="8,8,8,8">
        <Grid x:Name="GridMain">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="RowDefinitionMainInlays" Height="Auto" MinHeight="55"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TextBlockNullPage" Text="Нет доступных вкладок" VerticalAlignment="Center" TextAlignment="Center" Grid.Row="1"/>
            <Grid Grid.Row="1">
                <IEL:IELPageController x:Name="MainPageController" LeftAnimateSwitch="5,5,5,5" RightAnimateSwitch="-5,-5,-5,-5" Margin="5,5,5,5"/>
            </Grid>
            <Grid>
                <Border x:Name="BorderMainPage" Grid.Column="1" BorderThickness="0,0,0,2" BorderBrush="Black">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="BorderInlays" BorderBrush="Black" BorderThickness="0,0,1,0">
                            <IEL:IELScrollViewer x:Name="IELScrollViewerInlays" HorizontalAlignment="Left" ScrollForce="20">
                            </IEL:IELScrollViewer>
                        </Border>
                        <IEL:IELButtonImage x:Name="IELButtonAddInlay" x:FieldModifier="private" Grid.Column="1" Height="40" Width="40" CornerRadius="5,5,5,5" Margin="5,5,5,5"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
