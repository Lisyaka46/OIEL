<Base:IELContainerBase
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:Base="clr-namespace:IEL.UserElementsControl.Base;assembly=IEL"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:OIEL.UserElementsControl"
    xmlns:GUI="clr-namespace:IEL.UserElementsControl;assembly=IEL"
    xmlns:ObjectSettings="clr-namespace:IEL.CORE.Classes.ObjectSettings;assembly=IEL"
    xmlns:Classes="clr-namespace:IEL.CORE.Classes;assembly=IEL"
    x:Class="OIEL.UserElementsControl.OPLMediaViewer">
    <MediaElement x:Name="IndicatorMedia" Grid.Column="5" Stretch="UniformToFill" Margin="2,2,2,2" Opacity="0.8" Width="50" Height="50">
        <MediaElement.OpacityMask>
            <RadialGradientBrush>
                <GradientStop Color="Black" Offset="0.709"/>
                <GradientStop Color="#00000000" Offset="0.844"/>
            </RadialGradientBrush>
        </MediaElement.OpacityMask>
    </MediaElement>
</Base:IELContainerBase>
