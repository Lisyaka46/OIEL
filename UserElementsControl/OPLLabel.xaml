<Base:IELObjectBase
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:Base="clr-namespace:IEL.UserElementsControl.Base;assembly=IEL"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:GUI="clr-namespace:IEL.UserElementsControl;assembly=IEL"
    x:Class="OIEL.UserElementsControl.OPLLabelAction" 
             mc:Ignorable="d" Cursor="Hand" Width="110" Height="110">
    <Border x:Name="BorderMain" BorderThickness="2,2,2,2" BorderBrush="Black" CornerRadius="6,6,6,6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Border x:Name="BorderSelectElement" Grid.Row="0" Height="32" HorizontalAlignment="Right" Margin="0,-5,-5,0" CornerRadius="6,6,6,6" BorderThickness="2,2,2,2" Panel.ZIndex="1" BorderBrush="Black" Width="{Binding ActualWidth, ElementName=TextBlockNumberSelect, Mode=OneWay}" MinWidth="{Binding Height, ElementName=BorderSelectElement}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Image x:Name="ImageSelect"/>
                    <TextBlock x:Name="TextBlockNumberSelect" Text="001" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="{DynamicResource RussianRail G Pro}" Grid.Row="1"/>
                </Grid>
            </Border>
            <Grid Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="TextBlockNameLabel" TextWrapping="Wrap" Text="Text" FontSize="16" TextAlignment="Center" Foreground="Black" Grid.Row="1" Padding="2,0,2,2" FontFamily="{DynamicResource Bree CYR var}"/>
                <Grid>
                    <Image x:Name="ImageElementLabel" Grid.RowSpan="1" Grid.ColumnSpan="2"/>
                    <Image x:Name="ImageFaviconLabel" Grid.RowSpan="1" Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-5,-5,0,0">
                        <Image.OpacityMask>
                            <RadialGradientBrush>
                                <GradientStop Color="Black" Offset="0.686"/>
                                <GradientStop Color="#00000000" Offset="0.958"/>
                            </RadialGradientBrush>
                        </Image.OpacityMask>
                    </Image>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Base:IELObjectBase>
